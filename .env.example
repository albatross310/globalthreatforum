# Copy this file to .env and fill in your Supabase project credentials.
# SUPABASE_URL + anon key: Supabase dashboard → API Keys / Data API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Service-role (SECRET) key — used ONLY by the anchoring cron to bypass RLS.
# Supabase dashboard → API Keys → service_role / secret key. Never expose this.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Random shared secret protecting the /api/cron/anchor endpoint. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Set the SAME value in Vercel's env vars so Vercel Cron can authenticate.
CRON_SECRET=your-random-secret

# Public site origin, used to build the password-reset link sent by email.
# Optional in dev (falls back to the request origin); set it in production, e.g.
#   SITE_URL=https://globalthreatforum.com
# Also add this URL under Supabase → Authentication → URL Configuration →
# Redirect URLs, or the reset link will be rejected.
SITE_URL=https://globalthreatforum.com
